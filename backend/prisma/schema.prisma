// Prisma schema — 实体印记管理系统
// 数据源：SQLite（开发环境）

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// C 端用户账号状态
enum UserStatus {
  ACTIVE
  BANNED
}

/// 用户：登录凭证 + 个人名片信息
model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  passwordHash        String
  /// 邮箱是否已验证（注册时默认 false）
  isVerified          Boolean    @default(false)
  nickname            String
  signature           String     @default("")
  avatarUrl           String     @default("")
  /// 在游客页展示我的名片
  showCardOnGuestPage Boolean    @default(true)
  status              UserStatus @default(ACTIVE)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  memories            Memory[]
}

/// 印记：列表展示字段 + 详情内容，对应前端 ImprintListItem / ImprintArticle
model Memory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  /// 印记类型 id（可选），列表封面由类型映射图决定
  typeId       String?
  coverUrl     String   @default("")
  /// 瀑布流高度权重
  heightWeight Float    @default(1)
  /// 公开展示：开启则游客可看
  isPublic     Boolean  @default(false)
  /// 分享链接自定义后缀（字母与数字），全局唯一
  linkSuffix   String   @unique
  /// 详情正文
  content      String   @default("")
  /// 元信息，如「2024年5月16日 · 四川·稻城亚丁」
  meta         String   @default("")
  /// 图片 URL 列表，JSON 数组字符串存储
  images       String    @default("[]")
  /// 软删时间（M03 写入；null 表示未删除）
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([isPublic])
  @@index([deletedAt])
}

/// 管理端管理员角色
enum AdminRole {
  SUPER_ADMIN
  OPERATOR
  VIEWER
}

/// 管理端管理员状态
enum AdminStatus {
  ACTIVE
  DISABLED
}

/// 管理端管理员账号
model AdminUser {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  displayName  String
  role         AdminRole
  status       AdminStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}
