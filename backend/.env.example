# SQLite 数据库连接（推荐放在 backend 外层持久化目录）
# 例如：/srv/trail-memory/data/db/app.db
DATABASE_URL="file:../../data/db/dev.db"

# 上传目录（推荐放在 backend 外层持久化目录）
# 例如：/srv/trail-memory/data/uploads
UPLOAD_DIR="../data/uploads"

# 服务端口
PORT=3000

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# 跨域允许的前端地址（逗号分隔）
CORS_ORIGINS="http://localhost:5173"

# 是否开启邮箱验证（true 时注册后需验证邮件，暂不发送）
EMAIL_VERIFICATION="false"

# 管理端 JWT（必填，与 JWT_SECRET 不同）
ADMIN_JWT_SECRET="change-me-admin"
ADMIN_JWT_EXPIRES_IN="8h"

# 管理端前端跨域（逗号分隔）
ADMIN_CORS_ORIGINS="http://localhost:5174"
